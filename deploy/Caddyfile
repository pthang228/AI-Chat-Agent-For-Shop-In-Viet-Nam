# Caddy — TLS tự động (Let's Encrypt) + reverse proxy + phục vụ dashboard tĩnh.
# Mọi dịch vụ chung 1 DOMAIN; định tuyến theo path prefix mà từng service đã
# namespace. Biến {$DOMAIN}, {$ACME_EMAIL} lấy từ .env.production.

{
	email {$ACME_EMAIL}
}

{$DOMAIN} {
	encode gzip zstd

	# ── Kênh Meta (Messenger + Instagram) + webhook + đối soát tiền + bình luận ──
	handle /meta/* {
		reverse_proxy meta:5006
	}
	handle /fb/webhook* {
		reverse_proxy meta:5006
	}
	handle /payhook* {
		reverse_proxy meta:5006
	}
	handle /posts* {
		reverse_proxy meta:5006
	}
	handle /comments/* {
		reverse_proxy meta:5006
	}
	# Ảnh/media công khai (PUBLIC_BASE_URL/media/...) — meta phục vụ từ volume dùng chung
	handle /media/* {
		reverse_proxy meta:5006
	}

	# ── Các kênh khác (đã namespace path riêng) ──
	handle /tg/* {
		reverse_proxy telegram:5007
	}
	handle /shopee/* {
		reverse_proxy shopee:5009
	}
	handle /zalooa/* {
		reverse_proxy zalooa:5010
	}
	handle /webchat/* {
		reverse_proxy webchat:5011
	}
	handle /widget.js {
		reverse_proxy webchat:5011
	}

	# ── Zalo Node (đăng nhập QR): đi QUA BRIDGE (proxy /zalo-node/* có Bearer +
	# ép acc theo shop + whitelist endpoint) — KHÔNG proxy thẳng zalo-node:4000
	# nữa: route cũ phơi toàn bộ API Node (kể cả /send, /logout) ra internet
	# không auth. Giữ nguyên prefix (bridge route là /zalo-node/<sub>). ──
	handle /zalo-node/* {
		reverse_proxy bridge:5005
	}

	# ── API dashboard (bridge sở hữu namespace gốc) ──
	# LƯU Ý: /admin/shops* là API (→ bridge); còn /admin và /admin/shop/* là route
	# trang React (SPA) nên KHÔNG match ở đây — "shops" (số nhiều) tách khỏi "shop".
	@bridge path /auth/* /conversations /conversations/* /billing/* /orders /orders/* /prompt/* /notify/* /broadcasts /broadcasts/* /team /team/* /teammates /customers /customers/* /copilot/* /canned /canned/* /support/* /incoming /bot-status /bot-toggle /stats /stats/* /health /photos/* /admin/shops /admin/shops/* /zalo/* /sheets /sheets/*
	handle @bridge {
		reverse_proxy bridge:5005
	}

	# ── Còn lại = dashboard React (SPA): file tĩnh nếu có ({path}.html cho các
	# trang tĩnh như /privacy-policy — Meta App Review cần URL này), không thì SPA ──
	handle {
		root * /srv
		try_files {path} {path}.html /index.html
		file_server
	}
}
