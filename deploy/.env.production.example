# ============================================================================
#  NovaChat — CẤU HÌNH PRODUCTION.  Copy file này thành `.env.production` rồi điền.
#    cp .env.production.example .env.production && nano .env.production
#  KHÔNG commit .env.production lên git (đã ignore).
#  LƯU Ý: Docker đọc env_file KHÔNG bỏ chú thích cùng dòng → tuyệt đối KHÔNG
#  viết  KEY=value   # ghi chú  (phần # sẽ dính vào giá trị). Chú thích để RIÊNG dòng.
# ============================================================================

# ── BẮT BUỘC: domain + email cấp chứng chỉ TLS ──────────────────────────────
# DOMAIN = domain (hoặc subdomain DuckDNS) đã trỏ về IP VPS
DOMAIN=novachat.example.com
# ACME_EMAIL = email nhận cảnh báo Let's Encrypt
ACME_EMAIL=ban@gmail.com

# URL công khai (sinh link ảnh gửi khách + callback webhook) = https://<DOMAIN>
PUBLIC_BASE_URL=https://novachat.example.com
# Origin được phép gọi API (CORS)
ALLOWED_ORIGINS=https://novachat.example.com

# DB trong container (đã map volume) — KHÔNG sửa
HOMESTAY_DB_PATH=/app/data/homestay.db

# ── Bảo mật mạng (security.py) ──────────────────────────────────────────────
# FORCE_HTTPS=1: bật header HSTS (ép trình duyệt luôn dùng HTTPS).
# Chỉ bật khi chạy sau Caddy/TLS thật — stack này có Caddy nên để 1.
FORCE_HTTPS=1
# TRUST_PROXY=1: tin header X-Forwarded-For từ reverse proxy để rate-limit /
# khoá chống dò mật khẩu tính đúng IP CLIENT (không phải IP của Caddy).
# Chỉ bật khi có proxy tin cậy đứng trước (Caddy trong compose này) — để 1.
TRUST_PROXY=1

# ── BẮT BUỘC: khoá AI (bot trả lời) ─────────────────────────────────────────
DEEPSEEK_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=            # tuỳ chọn: mở khoá các model GPT cho shop chọn
AI_USD_VND=26500           # tỷ giá quy đổi bảng giá model
AI_PRICE_MARKUP=1.5        # hệ số lời trên giá gốc (1.5 = +50%; ĐỪNG hạ về 1.0 — bán usage không công)

# ── Meta (Messenger + Instagram) — điền khi kết nối FB ──────────────────────
FB_APP_ID=
FB_APP_SECRET=
FB_VERIFY_TOKEN=novachat_verify_token
FB_GRAPH_VERSION=v21.0
FB_ENABLE_IG=true

# ── Telegram (kênh + gọi điện Telethon tùy chọn) ────────────────────────────
TELEGRAM_OWNER_SETUP_CODE=chunha
# TELEGRAM_API_ID / HASH lấy ở my.telegram.org (chỉ cần cho tính năng gọi điện)
# Để TRỐNG thì bỏ 2 dòng dưới đi (đừng để dính chú thích)
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=

# ── Zalo OA / TikTok / Shopee — vendor app (cần nền tảng duyệt) ─────────────
# ZALO_OA_APP_ID=
# ZALO_OA_APP_SECRET=
# TIKTOK_VERIFY_TOKEN=
# SHOPEE_PARTNER_ID=
# SHOPEE_PARTNER_KEY=

# ── Bảo mật biên nội bộ (bridge ↔ Zalo Node) — BẮT BUỘC đặt khi production ──
# BRIDGE_SECRET: Node gửi kèm header X-Bridge-Secret khi POST /incoming;
# bridge từ chối request thiếu/sai secret (chống giả tin tắt bot 48h).
# NODE_API_KEY: Python gửi X-Node-Key khi gọi Node :4000; Node từ chối request
# thiếu khoá (chống ai cùng mạng gọi thẳng /send, /logout acc Zalo của shop).
# Tạo giá trị ngẫu nhiên dài, ví dụ:  openssl rand -hex 32  (mỗi khoá 1 giá trị)
BRIDGE_SECRET=
NODE_API_KEY=

# ── Bảo mật: mã hoá AT-REST session Telethon/token (app/core/secretbox.py) ──
# BẮT BUỘC: có PUBLIC_BASE_URL mà để trống là server TỪ CHỐI KHỞI ĐỘNG (fail-closed
# — không để token/session nằm thô trong DB). Đặt 1 chuỗi ngẫu nhiên DÀI, GIỮ BÍ
# MẬT, KHÔNG đổi (đổi = mọi acc gọi đăng nhập QR lại). Tạo: openssl rand -hex 32
NOVACHAT_SECRET_KEY=

# ── Thanh toán tự động (SePay/Casso) ────────────────────────────────────────
# LƯU Ý: khi có PUBLIC_BASE_URL (đã public), BẮT BUỘC đặt SEPAY_API_KEY —
# nếu không /payhook sẽ TỪ CHỐI mọi request (chống POST giả cộng ví).
# SEPAY_API_KEY=

# ── Billing ─────────────────────────────────────────────────────────────────
BILLING_PROMO_CODE=novachat7ngay
# BILLING_ADMIN_KEY=

# ── Cảnh báo vận hành (ops alerting) — KHUYẾN NGHỊ đặt khi có shop trả tiền ──
# Log ERROR của mọi service bắn thẳng vào Telegram NGƯỜI VẬN HÀNH (bot riêng
# cho ops, KHÔNG dùng chung bot của shop). Tạo bot qua @BotFather, lấy chat_id
# qua @userinfobot. Trống = tắt. Throttle mỗi logger 1 tin / 300s chống bão.
ALERT_TG_BOT_TOKEN=
ALERT_TG_CHAT_ID=
# ALERT_THROTTLE_SECS=300

# ── Vận hành ────────────────────────────────────────────────────────────────
SESSION_RETENTION_HOURS=720
WORKER_THREADS=8
SEND_RETRIES=2
BROADCAST_THROTTLE=1.5
# BẬT strict ở production: false = sự kiện Instagram KHÔNG cần chữ ký hợp lệ
# vẫn được xử lý → kẻ xấu POST giả /fb/webhook đốt cạn quota AI của shop.
FB_WEBHOOK_STRICT=true
SHOPEE_WEBHOOK_STRICT=false

# ── Đăng nhập Google cho dashboard (tùy chọn) ───────────────────────────────
# VITE_: nút Google trên web (build-time). GOOGLE_CLIENT_ID: backend kiểm
# id_token đúng app (aud) — đặt CÙNG 1 giá trị.
VITE_GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_ID=

# ── Email hệ thống: gửi mã quên mật khẩu (tùy chọn nhưng NÊN có) ─────────────
# Gmail: bật xác minh 2 bước → tạo App Password tại myaccount.google.com/apppasswords
SMTP_USER=
SMTP_PASS=
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_FROM=
