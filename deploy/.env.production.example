# ============================================================================
#  NovaChat — CẤU HÌNH PRODUCTION.  Copy file này thành `.env.production` rồi điền.
#    cp .env.production.example .env.production && nano .env.production
#  KHÔNG commit .env.production lên git (đã ignore).
# ============================================================================

# ── BẮT BUỘC: domain + email cấp chứng chỉ TLS ──────────────────────────────
DOMAIN=novachat.example.com          # domain đã trỏ A record về IP VPS
ACME_EMAIL=ban@gmail.com             # email nhận cảnh báo Let's Encrypt

# URL công khai (dùng để sinh link ảnh gửi khách + callback webhook). = https://<DOMAIN>
PUBLIC_BASE_URL=https://novachat.example.com
# Origin được phép gọi API (CORS). Để chính domain của bạn.
ALLOWED_ORIGINS=https://novachat.example.com

# DB + dữ liệu (trong container — KHÔNG sửa, đã map volume)
HOMESTAY_DB_PATH=/app/data/homestay.db

# ── BẮT BUỘC: khoá AI (bot trả lời) ─────────────────────────────────────────
DEEPSEEK_API_KEY=                    # chính (platform.deepseek.com)
GROQ_API_KEY=                        # dự phòng (console.groq.com) — nên có

# ── Meta (Messenger + Instagram) — điền khi kết nối FB ──────────────────────
FB_APP_ID=                           # App ID (Meta Developers)
FB_APP_SECRET=                       # App Secret — DÙNG cho chữ ký webhook + data-deletion
FB_VERIFY_TOKEN=haru_verify_token    # khớp với ô Verify Token khai webhook ở Meta
FB_GRAPH_VERSION=v21.0
FB_ENABLE_IG=true                    # bật Instagram (app đã setup IG product)

# ── Telegram (kênh + gọi điện Telethon tùy chọn) ────────────────────────────
TELEGRAM_BOT_TOKEN=                  # để trống nếu khách tự dán token trong web
TELEGRAM_OWNER_SETUP_CODE=chunha     # mã /start đăng ký chủ
TELEGRAM_API_ID=                     # my.telegram.org (cho tính năng gọi điện)
TELEGRAM_API_HASH=

# ── Zalo OA (kênh chính thức) — vendor app developers.zalo.me ───────────────
ZALO_OA_APP_ID=
ZALO_OA_APP_SECRET=

# ── TikTok / Shopee — vendor app (cần nền tảng duyệt) ───────────────────────
TIKTOK_VERIFY_TOKEN=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=

# ── Thanh toán tự động (SePay/Casso) ────────────────────────────────────────
SEPAY_API_KEY=                       # khớp key khai trên SePay; rỗng = nhận tất (KHÔNG nên ở prod)

# ── Billing ─────────────────────────────────────────────────────────────────
BILLING_PROMO_CODE=haru7ngay         # ĐỔI mã giới thiệu của bạn
BILLING_ADMIN_KEY=                   # đặt 1 chuỗi bí mật để xác nhận nạp tiền qua API

# ── Google Sheets (giá/phòng — chỉ nếu shop mẫu Haru dùng) ──────────────────
HARU_SHEET_ID=
MOCHI_SHEET_ID=

# ── Vận hành ────────────────────────────────────────────────────────────────
SESSION_RETENTION_HOURS=720          # giữ hội thoại 30 ngày
WORKER_THREADS=8
SEND_RETRIES=2
BROADCAST_THROTTLE=1.5
FB_WEBHOOK_STRICT=false
SHOPEE_WEBHOOK_STRICT=false

# ── Đăng nhập Google cho dashboard (build-time, tùy chọn) ───────────────────
# Tạo OAuth Client ID ở Google Cloud Console, thêm origin https://<DOMAIN>.
VITE_GOOGLE_CLIENT_ID=
